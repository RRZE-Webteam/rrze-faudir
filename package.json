{
  "name": "rrze-faudir",
  "version": "2.5.36-11",
  "description": "Plugin for displaying the FAUdir and institution directory on websites.",
  "main": "rrze-faudir.php",
  "textdomain": "rrze-faudir",
  "private": true,
  "scripts": {
    "build:block": "wp-scripts build",
    "start": "wp-scripts start",
    "format": "wp-scripts format --cwd faudir-block",
    "lint:css": "wp-scripts lint-style --cwd faudir-block",
    "lint:js": "wp-scripts lint-js --cwd faudir-block",
    "packages-update": "wp-scripts packages-update",
    "create-pot-for-blockeditor-l10n": "wp i18n make-pot . languages/rrze-faudir.pot --slug=rrze-faudir --domain=rrze-faudir --exclude=node_modules,src",
    "create-json-for-l10n": "wp i18n make-json languages/ --no-purge",
    "build:readme": "node scripts/build-readme.js",
    "bump:dev": "node scripts/build-version.js dev",
    "bump:prod": "node scripts/build-version.js prod",
    "build:dev": "node scripts/build-assets.js dev && npm run bump:dev && npm run build:readme",
    "build:prod": "node scripts/build-assets.js prod && npm run bump:prod && npm run build:readme && wp-scripts build"
  },
  "compatibility": {
    "wprequires": "6.7",
    "wptestedup": "6.9.1",
    "phprequires": "8.2"
  },
  "author": {
    "name": "RRZE-Webteam <webmaster@fau.de> (https://www.rrze.fau.de)",
    "url": "https://www.wordpress.rrze.fau.de"
  },
  "license": "GNU General Public License v3 or later",
  "licenseurl": "http://www.gnu.org/licenses/gpl-3.0.html",
  "tags": "Plugin, WordPress, FAUdir, FAU, RRZE",
  "repository": {
    "type": "git",
    "url": "https://github.com/RRZE-Webteam/rrze-faudir",
    "issues": "https://github.com/RRZE-Webteam/rrze-faudir/issues",
    "clone": "git+https://github.com/RRZE-Webteam/rrze-faudir.git"
  },
  "source": {
    "js": "./src/js/",
    "sass": "./src/scss/"
  },
  "target": {
    "js": "./assets/js/",
    "css": "./assets/css/",
    "mainjs": "rrze-faudir.js",
    "adminjs": "rrze-faudir-admin.js"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/wordpress__block-editor": "^14.21.2",
    "@types/wordpress__blocks": "^12.5.18",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@wordpress/scripts": "^31.4.0",
    "@wordpress/server-side-render": "^6.15.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-tsdoc": "^0.5.0",
    "sass": "^1.94.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@wordpress/dataviews": "^11.3.0",
    "esbuild": "^0.27.3"
  }
}
